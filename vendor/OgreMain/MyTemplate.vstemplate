<VSTemplate Version="3.0.0" xmlns="http://schemas.microsoft.com/developer/vstemplate/2005" Type="Project">
  <TemplateData>
    <Name>OgreMain</Name>
    <Description>&lt;No description available&gt;</Description>
    <ProjectType>VC</ProjectType>
    <ProjectSubType>
    </ProjectSubType>
    <SortOrder>1000</SortOrder>
    <CreateNewFolder>true</CreateNewFolder>
    <DefaultName>OgreMain</DefaultName>
    <ProvideDefaultName>true</ProvideDefaultName>
    <LocationField>Enabled</LocationField>
    <EnableLocationBrowseButton>true</EnableLocationBrowseButton>
    <Icon>__TemplateIcon.ico</Icon>
  </TemplateData>
  <TemplateContent>
    <Project TargetFileName="OgreMain.vcxproj" File="OgreMain.vcxproj" ReplaceParameters="true">
      <ProjectItem ReplaceParameters="false" TargetFileName="cmake_pch.cxx">CMAKEFILES\OGREMAIN.DIR\cmake_pch.cxx</ProjectItem>
      <ProjectItem ReplaceParameters="false" TargetFileName="cmake_pch.hxx">CMAKEFILES\OGREMAIN.DIR\DEBUG\cmake_pch.hxx</ProjectItem>
      <ProjectItem ReplaceParameters="false" TargetFileName="cmake_pch.hxx">CMAKEFILES\OGREMAIN.DIR\RELEASE\cmake_pch.hxx</ProjectItem>
      <ProjectItem ReplaceParameters="false" TargetFileName="cmake_pch.hxx">CMAKEFILES\OGREMAIN.DIR\MINSIZEREL\cmake_pch.hxx</ProjectItem>
      <ProjectItem ReplaceParameters="false" TargetFileName="cmake_pch.hxx">CMAKEFILES\OGREMAIN.DIR\RELWITHDEBINFO\cmake_pch.hxx</ProjectItem>
      <ProjectItem ReplaceParameters="false" TargetFileName="$projectname$.vcxproj.filters">OgreMain.vcxproj.filters</ProjectItem>
    </Project>
  </TemplateContent>
</VSTemplate>